# Telegram bot token from @BotFather
BOT_TOKEN=123456:replace-with-your-token

# SQLite database file path
DATABASE_PATH=data/bot.db

# Timezone for scheduled jobs (IANA name)
TIMEZONE=Europe/Moscow

# Max participants per running club edition
CAPACITY=30

# Comma-separated Telegram user IDs who can use admin commands
ADMIN_IDS=123456789,987654321

# Cron times (HH:MM, in TIMEZONE) for the weekly jobs
MONDAY_OPEN_TIME=10:00
FRIDAY_REMINDER_TIME=09:00
